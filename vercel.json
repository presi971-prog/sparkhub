{
  "crons": [
    {
      "path": "/api/content-machine/generate-daily",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/sparkscan/rescan-weekly",
      "schedule": "0 10 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "decouvrir.digital-code-growth.com" }],
      "destination": "/assistant-ia",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "sparkgrowth.digital-code-growth.com" }],
      "destination": "/sparkgrowth",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "sparkgrowth-dcg.vercel.app" }],
      "destination": "/sparkgrowth",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/demo-site/:path*",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors *"
        }
      ]
    },
    {
      "source": "/api/chat-demo",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors *"
        }
      ]
    },
    {
      "source": "/((?!demo-site|api/chat-demo).*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), geolocation=(self), microphone=(self)"
        },
        {
          "key": "X-DNS-Prefetch-Control",
          "value": "on"
        }
      ]
    }
  ]
}
